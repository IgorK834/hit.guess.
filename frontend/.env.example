# Skopiuj do `.env.local` i ewentualnie zmień adres API.
# Next.js wczytuje zmienne NEXT_PUBLIC_* przy starcie `npm run dev` / `npm run build`.

NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev: konsola window.hitguess.reset() / .wipe(), przyciski DEV — po zmianie zrestartuj dev server.
# NEXT_PUBLIC_DEV_MODE=true

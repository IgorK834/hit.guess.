# Skopiuj do `.env.local` i ewentualnie zmień adres API.
# Next.js wczytuje zmienne NEXT_PUBLIC_* przy starcie `npm run dev` / `npm run build`.
#
# Production (Railway Docker): pass the same value as a Docker build-arg
# `NEXT_PUBLIC_API_URL` (Railway → frontend service → Variables → Docker Build Args),
# e.g. https://your-api.up.railway.app — bez końcowego slasha.

NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev Mode (QA / admin) — całe UI DEV powinno być wyłączone w produkcji.
# Ustaw w `.env.local`, potem zrestartuj `pnpm dev`.
#
# Preferowane:
# NEXT_PUBLIC_ENABLE_DEV_MODE=true
#
# Back-compat:
# NEXT_PUBLIC_DEV_MODE=true

# Backend admin token for hidden dashboard (`X-Admin-Token`).
# Put this in `backend/.env.local`, not in frontend env.
# ADMIN_TOKEN=your-secret-token

# Skopiuj do `.env.local` i ewentualnie zmień adres API.
# Next.js wczytuje zmienne NEXT_PUBLIC_* przy starcie `npm run dev` / `npm run build`.

NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev Mode (QA / admin) — całe UI DEV powinno być wyłączone w produkcji.
# Ustaw w `.env.local`, potem zrestartuj `pnpm dev`.
#
# Preferowane:
# NEXT_PUBLIC_ENABLE_DEV_MODE=true
#
# Back-compat:
# NEXT_PUBLIC_DEV_MODE=true

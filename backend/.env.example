# Copy to `.env` or `.env.local` for local runs. On Railway, set these in the service Variables UI.

# --- Required (Railway Postgres plugin: reference variable DATABASE_URL) ---
DATABASE_URL=postgresql+asyncpg://hitguess:hitguess@localhost:5432/hitguess

# --- Required (Railway Redis plugin: reference variable REDIS_URL) ---
REDIS_URL=redis://localhost:6379/0

# --- TIDAL (required for search, daily metadata, previews) ---
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=

# --- CORS: comma-separated browser origins (no spaces). MUST include your production frontend URL(s), e.g.:
# CORS_ALLOW_ORIGINS=https://hitguess-frontend.up.railway.app,https://hitguess.com
#
# Optional: allow all Railway *.up.railway.app HTTPS frontends (staging convenience; prefer explicit origins in prod):
# CORS_ALLOW_ORIGIN_REGEX=^https://[a-z0-9-]+\.up\.railway\.app$
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Optional ---
# DEBUG=true
# TIDAL_COUNTRY_CODE=PL
# ADMIN_TOKEN=change-me-for-admin-dashboard
# STRICT_CATEGORY_LOGIC=false
# SCHEDULER_TIMEZONE=Europe/Warsaw

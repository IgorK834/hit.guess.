# Tracked defaults — copy secrets into backend/.env.local (gitignored); values there override these.

# Async SQLAlchemy (must use asyncpg driver)
DATABASE_URL=postgresql+asyncpg://hitguess:hitguess@localhost:5432/hitguess

# Redis (DB index 0 = default)
REDIS_URL=redis://localhost:6379/0

# TIDAL OAuth (set in .env.local)
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
# TIDAL_TOKEN_URL=https://auth.tidal.com/v1/oauth2/token

# TIDAL Open API
# TIDAL_OPENAPI_BASE_URL=https://openapi.tidal.com/v2
# TIDAL_COUNTRY_CODE=PL
# TIDAL_PLACEHOLDER_COVER_URL=https://tidal.com/

# SCHEDULER_TIMEZONE=Europe/Warsaw

# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DEBUG=false
